#version 430

layout (local_size_x = 64) in; // workgroup size

// Example: write thread ID into buffer
layout(std430, binding = 0) buffer PixelBits1 {
    uint bits1[]; // bit-packed pixels
};
layout(std430, binding = 1) buffer PixelBits2 {
    uint bits2[]; // bit-packed pixels
};

void main() {
    bits1[gl_GlobalInvocationID.x] = bits2[gl_GlobalInvocationID.x];
}
